{
  "name": "@feedmob/feedmob-client-reports",
  "version": "0.0.1",
  "description": "MCP server for querying FeedMob client reports data.",
  "main": "src/index.ts",
  "homepage": "https://github.com/feed-mob/fm-mcp-servers",
  "bugs": "https://github.com/feed-mob/fm-mcp-servers/issues",
  "type": "module",
  "bin": {
    "feedmob-client-reports": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "inspect": "fastmcp inspect src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "client-reports"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "author": "FeedMob",
  "license": "ISC",
  "dependencies": {
    "fastmcp": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "shx": "^0.3.4",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/feed-mob/fm-mcp-servers"
  }
}
