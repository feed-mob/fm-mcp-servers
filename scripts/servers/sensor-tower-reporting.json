{
  "serverKey": "sensor-tower-reporting",
  "displayName": "Sensor Tower Reporting (Deprecated)",
  "packageName": "@feedmob/sensor-tower-reporting",
  "deprecated": true,
  "migrationUrl": "https://insights-mcp.feedmob.com/sensortower",
  "command": {
    "type": "npx",
    "args": ["-y", "@feedmob/sensor-tower-reporting"]
  },
  "env": [
    {
      "name": "AUTH_TOKEN",
      "label": "AUTH_TOKEN",
      "description": "Sensor Tower API auth token",
      "required": true,
      "secret": true
    },
    {
      "name": "SENSOR_TOWER_BASE_URL",
      "label": "SENSOR_TOWER_BASE_URL",
      "description": "Sensor Tower API base URL",
      "required": false,
      "secret": false,
      "default": "https://api.sensortower.com"
    }
  ],
  "macos": {
    "injectPath": true
  },
  "postInstallMessage": [
    "Deprecated: migrate to the hosted SensorTower MCP at https://insights-mcp.feedmob.com/sensortower",
    "Fully quit Claude Desktop",
    "Reopen Claude Desktop to load the MCP server"
  ]
}
